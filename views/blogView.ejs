<%- include('./partials/start.ejs') %>
    <div class="col-lg-10 p-4">
        <div class="d-flex justify-content-end mb-3">
            <a href="/blog/" class="btn btn-sm btn-outline-secondary">
                Back to Dashboard
            </a>
        </div>
        <div class="d-flex justify-content-center">
            <div class="card blog-view-card border-0 shadow">
                <img src="/<%= blog.file %>" class="blog-view-img" alt="<%= blog.name %>">
                <div class="card-body">
                    <h3 class="mb-3">
                        <%= blog.name %>
                    </h3>
                    <div class="mb-3">
                        <% blog.tags.split(',').forEach(tag=> { %>
                            <span class="badge custom-tag me-1">
                                <%= tag.trim() %>
                            </span>
                            <% }) %>
                    </div>
                    <p class="text-muted">
                        <%= blog.desc %>
                    </p>
                </div>
            </div>
        </div>
    </div>

<%- include('./partials/end.ejs') %>