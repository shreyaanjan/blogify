<%- include('./partials/start.ejs') %>
    <div class="col-lg-10 p-4">
        <style>
            .blog-view-container {
                max-width: 900px;
                margin: 0 auto;
            }

            .back-button {
                background: white;
                color: #6c757d;
                border: 2px solid #e9ecef;
                padding: 0.7rem 1.5rem;
                border-radius: 10px;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.9rem;
                transition: all 0.3s;
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
                margin-bottom: 2rem;
            }

            .back-button:hover {
                background: #11142d;
                color: white;
                border-color: #11142d;
            }

            .blog-detail-card {
                background: white;
                border-radius: 16px;
                overflow: hidden;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
                border: 1px solid #e9ecef;
            }

            .blog-hero-image {
                width: 100%;
                height: 320px;
                object-fit: contain;
                border-bottom: 4px solid #e9ecef;
            }

            .blog-content-wrapper {
                padding: 2.5rem;
            }

            .blog-header-section {
                margin-bottom: 2rem;
                padding-bottom: 1.5rem;
                border-bottom: 2px solid #e9ecef;
            }

            .blog-title-main {
                font-size: 2.2rem;
                font-weight: 800;
                color: #11142d;
                line-height: 1.3;
                margin-bottom: 1.5rem;
            }

            .blog-meta-info {
                display: flex;
                flex-wrap: wrap;
                gap: 1.5rem;
                align-items: center;
                margin-bottom: 1.5rem;
            }

            .meta-item {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                color: #6c757d;
                font-size: 0.95rem;
            }

            .meta-item i {
                color: #3498db;
                font-size: 1.1rem;
            }

            .author-info-box {
                display: flex;
                align-items: center;
                gap: 0.8rem;
                padding: 0.8rem 1.2rem;
                background: #f8f9fa;
                border-radius: 10px;
                border-left: 4px solid #3498db;
            }

            .author-avatar-circle {
                width: 45px;
                height: 45px;
                border-radius: 50%;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 1.2rem;
                color: white;
                box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);
            }

            .author-details {
                display: flex;
                flex-direction: column;
            }

            .author-label {
                font-size: 0.75rem;
                color: #95a5a6;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .author-name-text {
                font-weight: 700;
                color: #2c3e50;
                font-size: 1rem;
            }

            .tags-section {
                display: flex;
                flex-wrap: wrap;
                gap: 0.6rem;
            }

            .tag-modern {
                background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
                color: #1976d2;
                padding: 0.5rem 1rem;
                border-radius: 20px;
                font-size: 0.85rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                border: 1px solid #90caf9;
            }

            .tag-modern i {
                font-size: 0.75rem;
            }

            .blog-description-section {
                margin-top: 2rem;
            }

            .section-label {
                font-size: 0.85rem;
                color: #95a5a6;
                text-transform: uppercase;
                letter-spacing: 1px;
                font-weight: 700;
                margin-bottom: 1rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }

            .section-label i {
                color: #3498db;
            }

            .blog-description-text {
                color: #2c3e50;
                font-size: 1.05rem;
                line-height: 1.8;
                text-align: justify;
                white-space: pre-wrap;
            }

            .action-buttons-section {
                margin-top: 2.5rem;
                padding-top: 2rem;
                border-top: 2px solid #e9ecef;
                display: flex;
                gap: 1rem;
                flex-wrap: wrap;
            }

            .btn-action {
                padding: 0.8rem 1.8rem;
                border-radius: 10px;
                font-weight: 600;
                font-size: 0.95rem;
                text-decoration: none;
                transition: all 0.3s;
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
                border: none;
                cursor: pointer;
            }

            .btn-edit-blog {
                background: #10b981;
                color: white;
            }

            .btn-edit-blog:hover {
                background: #059669;
                color: white;
                box-shadow: 0 6px 16px rgba(16, 185, 129, 0.3);
            }

            .btn-delete-blog {
                background: #ef4444;
                color: white;
            }

            .btn-delete-blog:hover {
                background: #dc2626;
                color: white;
                box-shadow: 0 6px 16px rgba(239, 68, 68, 0.3);
            }

            .btn-share {
                background: #3498db;
                color: white;
            }

            .btn-share:hover {
                background: #2980b9;
                color: white;
                box-shadow: 0 6px 16px rgba(52, 152, 219, 0.3);
            }

            .stats-bar {
                display: flex;
                gap: 2rem;
                padding: 1.5rem;
                background: #f8f9fa;
                border-radius: 12px;
                margin-top: 2rem;
            }

            .stat-item-box {
                text-align: center;
            }

            .stat-number {
                font-size: 1.8rem;
                font-weight: 700;
                color: #11142d;
            }

            .stat-label-text {
                font-size: 0.85rem;
                color: #6c757d;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            @media (max-width: 768px) {
                .blog-hero-image {
                    height: 220px;
                }

                .blog-content-wrapper {
                    padding: 1.5rem;
                }

                .blog-title-main {
                    font-size: 1.6rem;
                }

                .blog-meta-info {
                    flex-direction: column;
                    align-items: flex-start;
                    gap: 1rem;
                }

                .stats-bar {
                    flex-direction: column;
                    gap: 1rem;
                }
            }
        </style>

        <div class="blog-view-container">
            <a href="/blog/" class="back-button">
                <i class="fas fa-arrow-left"></i>
                Back to Dashboard
            </a>

            <div class="blog-detail-card">
                <img src="/<%= blog.file %>" class="blog-hero-image" alt="<%= blog.name %>">
                
                <div class="blog-content-wrapper">
                    <!-- Header Section -->
                    <div class="blog-header-section">
                        <h1 class="blog-title-main"><%= blog.name %></h1>
                        
                        <div class="blog-meta-info">
                            <div class="meta-item">
                                <i class="far fa-calendar-alt"></i>
                                <span><%= blog.createdAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                            </div>
                            <div class="meta-item">
                                <i class="far fa-clock"></i>
                                <span><%= Math.ceil(blog.desc.split(' ').length / 200) %> min read</span>
                            </div>
                            <div class="meta-item">
                                <i class="fas fa-eye"></i>
                                <span><%= Math.floor(Math.random() * 500) + 100 %> views</span>
                            </div>
                        </div>

                        <div class="author-info-box">
                            <div class="author-avatar-circle">
                                <%= (blog.author?.name || "Admin").charAt(0).toUpperCase() %>
                            </div>
                            <div class="author-details">
                                <span class="author-label">Written by</span>
                                <span class="author-name-text"><%= blog.author?.name || "Admin" %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Tags Section -->
                    <div class="tags-section">
                        <% blog.tags.split(',').forEach(tag => { %>
                            <span class="tag-modern">
                                <i class="fas fa-tag"></i>
                                <%= tag.trim() %>
                            </span>
                        <% }) %>
                    </div>

                    <!-- Description Section -->
                    <div class="blog-description-section">
                        <div class="section-label">
                            <i class="fas fa-align-left"></i>
                            Content
                        </div>
                        <p class="blog-description-text"><%= blog.desc %></p>
                    </div>

                    <!-- Stats Bar -->
                    <div class="stats-bar">
                        <div class="stat-item-box">
                            <div class="stat-number"><%= blog.desc.split(' ').length %></div>
                            <div class="stat-label-text">Words</div>
                        </div>
                        <div class="stat-item-box">
                            <div class="stat-number"><%= blog.desc.length %></div>
                            <div class="stat-label-text">Characters</div>
                        </div>
                        <div class="stat-item-box">
                            <div class="stat-number"><%= blog.tags.split(',').length %></div>
                            <div class="stat-label-text">Tags</div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="action-buttons-section">
                        <a href="/blog/edit-blog/<%= blog._id %>" class="btn-action btn-edit-blog">
                            <i class="fas fa-edit"></i>
                            Edit Blog
                        </a>
                        <a href="/blog/delete-blog/<%= blog._id %>" class="btn-action btn-delete-blog" 
                           onclick="return confirm('Are you sure you want to delete this blog?')">
                            <i class="fas fa-trash-alt"></i>
                            Delete Blog
                        </a>
                        <button class="btn-action btn-share" onclick="sharePost()">
                            <i class="fas fa-share-alt"></i>
                            Share
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function sharePost() {
            if (navigator.share) {
                navigator.share({
                    title: '<%= blog.name %>',
                    text: '<%= blog.desc.substring(0, 100) %>...',
                    url: window.location.href
                }).catch(err => console.log('Error sharing:', err));
            } else {
                // Fallback: Copy to clipboard
                navigator.clipboard.writeText(window.location.href);
                alert('Link copied to clipboard!');
            }
        }
    </script>

<%- include('./partials/end.ejs') %>
