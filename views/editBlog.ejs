<%- include('./partials/start.ejs') %>
    <div class="col-lg-10 p-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <h4 class="mb-4 fw-semibold" style="color:#11142d;">Edit Blog</h4>
                <form action="/blog/edit-blog/<%= editBlog._id %>" method="post" enctype="multipart/form-data">
                    <div class="mb-3 d-flex justify-content-between gap-3">
                        <div class="w-100">
                            <label for="name" class="form-label">Name</label>
                            <input type="text" value="<%- editBlog.name %>" class="form-control" id="name" name="name">
                        </div>
                        <div class="w-100">
                            <label for="file" class="form-label">Cover</label>
                            <input type="file" value="<%- editBlog.fileName %>" class="form-control" id="file"
                                name="file" accept="image/*">
                            <img src="/<%= editBlog.file %>" alt="<%= editBlog.name %>" width="150px">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="desc" class="form-label">Description</label>
                        <textarea class="form-control" name="desc" id="desc" rows="5"><%- editBlog.desc %></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="tags" class="form-label">Tags</label>
                        <input type="text" value="<%- editBlog.tags %>" class="form-control" name="tags" id="tags">
                    </div>
                    <button class="btn px-4 py-2 text-white"
                        style="background-color:#11142d; border-radius:12px;">Update
                        Your Blog</button>
                </form>
            </div>
        </div>
    </div>
    <%- include('./partials/end.ejs') %>