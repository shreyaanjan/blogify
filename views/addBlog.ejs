<%- include('./partials/start.ejs') %>
    <div class="col-lg-10 p-4">
        <style>
            .form-container {
                background: white;
                border-radius: 12px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
                border: 1px solid #e9ecef;
                padding: 2rem;
            }

            .form-header {
                margin-bottom: 2rem;
                padding-bottom: 1rem;
                border-bottom: 2px solid #e9ecef;
            }

            .form-title {
                font-size: 1.8rem;
                font-weight: 700;
                color: #11142d;
                margin: 0;
                display: flex;
                align-items: center;
                gap: 0.8rem;
            }

            .form-subtitle {
                color: #6c757d;
                font-size: 0.95rem;
                margin-top: 0.5rem;
            }

            .form-label {
                font-weight: 600;
                color: #2c3e50;
                margin-bottom: 0.5rem;
                font-size: 0.95rem;
                display: flex;
                align-items: center;
                gap: 0.4rem;
            }

            .form-control, .form-select {
                border: 2px solid #e9ecef;
                border-radius: 10px;
                padding: 0.75rem 1rem;
                font-size: 0.95rem;
                transition: all 0.3s;
            }

            .form-control:focus, .form-select:focus {
                border-color: #3498db;
                box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
            }

            .input-group-custom {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 1.5rem;
            }

            .form-group {
                margin-bottom: 1.5rem;
            }

            .file-input-wrapper {
                position: relative;
            }

            .file-input-label {
                display: block;
                padding: 0.75rem 1rem;
                background-color: #f8f9fa;
                border: 2px dashed #dee2e6;
                border-radius: 10px;
                text-align: center;
                cursor: pointer;
                transition: all 0.3s;
            }

            .file-input-label:hover {
                background-color: #e9ecef;
                border-color: #3498db;
            }

            .file-input-label i {
                font-size: 2rem;
                color: #3498db;
                display: block;
                margin-bottom: 0.5rem;
            }

            .file-input-text {
                color: #6c757d;
                font-size: 0.9rem;
            }

            input[type="file"] {
                display: none;
            }

            textarea.form-control {
                resize: vertical;
                min-height: 150px;
            }

            .btn-submit {
                background-color: #11142d;
                color: white;
                padding: 0.9rem 2.5rem;
                border-radius: 10px;
                border: none;
                font-weight: 600;
                font-size: 1rem;
                transition: all 0.3s;
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
            }

            .btn-submit:hover {
                background-color: #1c1f4a;
                box-shadow: 0 6px 16px rgba(17, 20, 45, 0.3);
            }

            .btn-cancel {
                background-color: #e9ecef;
                color: #495057;
                padding: 0.9rem 2rem;
                border-radius: 10px;
                border: none;
                font-weight: 600;
                font-size: 1rem;
                transition: all 0.3s;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
                margin-left: 1rem;
            }

            .btn-cancel:hover {
                background-color: #dee2e6;
                color: #495057;
            }

            .helper-text {
                font-size: 0.85rem;
                color: #6c757d;
                margin-top: 0.4rem;
            }

            @media (max-width: 768px) {
                .input-group-custom {
                    grid-template-columns: 1fr;
                }
            }
        </style>

        <div class="form-container">
            <div class="form-header">
                <h1 class="form-title">
                    ✍️ Add New Blog
                </h1>
                <p class="form-subtitle">Create and publish your amazing content</p>
            </div>

            <form action="/blog/add-blog" method="post" enctype="multipart/form-data">
                <div class="input-group-custom">
                    <div class="form-group">
                        <label for="name" class="form-label">
                            📝 Blog Title
                        </label>
                        <input type="text" class="form-control" id="name" name="name"
                            placeholder="Enter an engaging title" required>
                        <div class="helper-text">Make it catchy and descriptive</div>
                    </div>

                    <div class="form-group">
                        <label for="file" class="form-label">
                            🖼️ Cover Image
                        </label>
                        <div class="file-input-wrapper">
                            <label for="file" class="file-input-label">
                                <i class="fas fa-cloud-upload-alt"></i>
                                <span class="file-input-text">Click to upload image</span>
                            </label>
                            <input type="file" class="form-control" id="file" name="file" accept="image/*">
                        </div>
                        <div class="helper-text">Recommended: 1200x630px</div>
                    </div>
                </div>

                <div class="form-group">
                    <label for="desc" class="form-label">
                        📄 Description
                    </label>
                    <textarea class="form-control" name="desc" id="desc" rows="8"
                        placeholder="Write your blog content here..."></textarea>
                    <div class="helper-text">Share your thoughts, ideas, and stories</div>
                </div>

                <div class="form-group">
                    <label for="tags" class="form-label">
                        🏷️ Tags
                    </label>
                    <input type="text" class="form-control" name="tags" id="tags"
                        placeholder="tech, javascript, web development">
                    <div class="helper-text">Separate tags with commas</div>
                </div>

                <div class="d-flex align-items-center">
                    <button type="submit" class="btn-submit">
                        <i class="fas fa-paper-plane"></i>
                        Publish Blog
                    </button>
                    <a href="/blog/" class="btn-cancel">
                        <i class="fas fa-times"></i>
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
        // File input preview
        document.getElementById('file').addEventListener('change', function(e) {
            const fileName = e.target.files[0]?.name;
            if (fileName) {
                document.querySelector('.file-input-text').textContent = fileName;
            }
        });
    </script>
<%- include('./partials/end.ejs') %>
