<%- include('./partials/start.ejs') %>
    <div class="col-lg-10 p-4">
        <style>
            .profile-header {
                background: white;
                padding: 2rem;
                border-radius: 12px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
                margin-bottom: 2rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
                border-left: 4px solid #3498db;
            }

            .profile-info {
                display: flex;
                align-items: center;
                gap: 1.5rem;
            }

            .profile-avatar {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2rem;
                font-weight: 700;
                color: white;
                box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
            }

            .profile-details h1 {
                font-size: 1.8rem;
                font-weight: 700;
                color: #11142d;
                margin: 0;
            }

            .profile-subtitle {
                color: #6c757d;
                font-size: 0.95rem;
                margin-top: 0.3rem;
            }

            .btn-add-blog {
                background-color: #11142d;
                color: white;
                padding: 0.8rem 1.8rem;
                border-radius: 10px;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.95rem;
                transition: all 0.3s;
                display: inline-flex;
                align-items: center;
                gap: 0.6rem;
            }

            .btn-add-blog:hover {
                background-color: #1c1f4a;
                color: white;
                box-shadow: 0 6px 16px rgba(17, 20, 45, 0.3);
            }

            .stats-row {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 1rem;
                margin-bottom: 2rem;
            }

            .stat-box {
                background: white;
                padding: 1.5rem;
                border-radius: 12px;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
                text-align: center;
            }

            .stat-number {
                font-size: 2rem;
                font-weight: 700;
                color: #11142d;
            }

            .stat-label {
                color: #6c757d;
                font-size: 0.9rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-top: 0.3rem;
            }

            .empty-state {
                background: white;
                padding: 4rem 2rem;
                border-radius: 12px;
                text-align: center;
                border: 2px dashed #dee2e6;
            }

            .empty-state i {
                font-size: 4rem;
                color: #dee2e6;
                margin-bottom: 1rem;
            }

            .empty-state h3 {
                font-size: 1.5rem;
                color: #6c757d;
                margin-bottom: 0.8rem;
            }

            .empty-state p {
                color: #95a5a6;
                margin-bottom: 1.5rem;
            }

            .modern-blog-card {
                background: white;
                border-radius: 12px;
                overflow: hidden;
                box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
                transition: all 0.3s ease;
                border: 1px solid #e9ecef;
                height: 100%;
                display: flex;
                flex-direction: column;
            }

            .modern-blog-card:hover {
                box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
            }

            .modern-blog-img {
                width: 100%;
                height: 200px;
                object-fit: cover;
                border-bottom: 3px solid #3498db;
            }

            .modern-blog-body {
                padding: 1.3rem;
                display: flex;
                flex-direction: column;
                flex-grow: 1;
            }

            .blog-tags-row {
                display: flex;
                flex-wrap: wrap;
                gap: 0.4rem;
                margin-bottom: 0.8rem;
            }

            .modern-tag {
                background-color: #e3f2fd;
                color: #1976d2;
                padding: 0.3rem 0.7rem;
                border-radius: 20px;
                font-size: 0.7rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.3px;
            }

            .modern-blog-title {
                font-size: 1.2rem;
                font-weight: 700;
                color: #2c3e50;
                margin-bottom: 0.7rem;
                line-height: 1.4;
            }

            .modern-blog-desc {
                color: #6c757d;
                font-size: 0.9rem;
                line-height: 1.6;
                margin-bottom: 1rem;
                flex-grow: 1;
            }

            .blog-actions {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding-top: 1rem;
                border-top: 1px solid #e9ecef;
                margin-top: auto;
            }

            .btn-read {
                background-color: #11142d;
                color: white;
                padding: 0.5rem 1rem;
                border-radius: 8px;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.85rem;
                transition: all 0.3s;
            }

            .btn-read:hover {
                background-color: #1c1f4a;
                color: white;
            }

            .action-buttons {
                display: flex;
                gap: 0.5rem;
            }

            .btn-edit {
                background-color: #10b981;
                color: white;
                padding: 0.5rem 0.9rem;
                border-radius: 8px;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.85rem;
                transition: all 0.3s;
            }

            .btn-edit:hover {
                background-color: #059669;
                color: white;
            }

            .btn-delete {
                background-color: #ef4444;
                color: white;
                padding: 0.5rem 0.9rem;
                border-radius: 8px;
                text-decoration: none;
                font-weight: 600;
                font-size: 0.85rem;
                transition: all 0.3s;
            }

            .btn-delete:hover {
                background-color: #dc2626;
                color: white;
            }

            @media (max-width: 768px) {
                .profile-header {
                    flex-direction: column;
                    text-align: center;
                    gap: 1.5rem;
                }

                .profile-info {
                    flex-direction: column;
                }

                .stats-row {
                    grid-template-columns: 1fr;
                }
            }
        </style>

        <div class="profile-header">
            <div class="profile-info">
                <div class="profile-avatar">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <div class="profile-details">
                    <h1>
                        <%= user.name %>'s Profile
                    </h1>
                    <p class="profile-subtitle">Manage and view all your published blogs</p>
                </div>
            </div>
            <a href="/blog/add-blog" class="btn-add-blog">
                <i class="fas fa-plus-circle"></i>
                Create New Blog
            </a>
        </div>

        <div class="stats-row">
            <div class="stat-box">
                <div class="stat-number">
                    <%= userBlogs.length %>
                </div>
                <div class="stat-label">Total Blogs</div>
            </div>
            <div class="stat-box">
                <div class="stat-number">
                    <%= new Set(userBlogs.map(b=> b.tags)).size %>
                </div>
                <div class="stat-label">Unique Tags</div>
            </div>
            <div class="stat-box">
                <div class="stat-number">
                    <%= userBlogs.reduce((sum, b)=> sum + b.desc.length, 0) %>
                </div>
                <div class="stat-label">Total Words</div>
            </div>
        </div>

        <div class="row g-4">
            <% if (userBlogs.length===0) { %>
                <div class="col-12">
                    <div class="empty-state">
                        <i class="fas fa-pen-fancy"></i>
                        <h3>No Blogs Yet</h3>
                        <p>Start sharing your thoughts and ideas with the world!</p>
                        <a href="/blog/add-blog" class="btn-add-blog">
                            <i class="fas fa-plus-circle"></i>
                            Write Your First Blog
                        </a>
                    </div>
                </div>
                <% } %>

                    <% userBlogs.forEach(blog=> { %>
                        <div class="col-sm-12 col-md-6 col-lg-4">
                            <div class="modern-blog-card">
                                <img src="/<%= blog.file %>" class="modern-blog-img" alt="<%= blog.name %>">
                                <div class="modern-blog-body">
                                    <div class="blog-tags-row">
                                        <% blog.tags.split(',').slice(0, 3).forEach(tag=> { %>
                                            <span class="modern-tag">
                                                <%= tag.trim() %>
                                            </span>
                                            <% }) %>
                                    </div>

                                    <h5 class="modern-blog-title">
                                        <%= blog.name %>
                                    </h5>

                                    <p class="modern-blog-desc">
                                        <%= blog.desc.length> 120 ? blog.desc.slice(0, 120) + '...' : blog.desc %>
                                    </p>

                                    <div class="blog-actions">
                                        <a href="/blog/<%= blog._id %>" class="btn-read">
                                            Read More →
                                        </a>
                                        <div class="action-buttons">
                                            <a href="/blog/edit-blog/<%= blog._id %>" class="btn-edit">
                                                <i class="fas fa-edit"></i>
                                                Edit
                                            </a>
                                            <a href="/blog/delete-blog/<%= blog._id %>" class="btn-delete"
                                                onclick="return confirm('Are you sure you want to delete this blog?')">
                                                <i class="fas fa-trash-alt"></i>
                                                Delete
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
        </div>
    </div>
    <%- include('./partials/end.ejs') %>