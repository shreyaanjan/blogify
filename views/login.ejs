<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Blogify • Login</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0d1026, #11142d);
        }

        .login-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 18px;
        }

        .brand {
            color: #11142d;
            font-weight: 600;
            letter-spacing: 1px;
        }

        .form-control {
            border-radius: 12px;
            padding: 11px 14px;
        }

        .form-control:focus {
            border-color: #11142d;
            box-shadow: 0 0 0 0.15rem rgba(17, 20, 45, 0.2);
        }

        .btn-login {
            background-color: #11142d;
            border: none;
            border-radius: 12px;
            padding: 10px;
        }

        .btn-login:hover {
            background-color: #1a1e4f;
        }

        .forgot-link {
            font-size: 0.9rem;
            color: #11142d;
            text-decoration: none;
        }

        .forgot-link:hover {
            text-decoration: underline;
        }

        a {
            color: #11142d;
            font-weight: 500;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div class="container d-flex justify-content-center align-items-center min-vh-100">
        <div class="card shadow-lg p-4 login-card" style="width: 100%; max-width: 400px;">
            <h3 class="text-center brand mb-2">Blogify</h3>
            <p class="text-center text-muted mb-4">Login to your dashboard</p>
            <form action="/auth/login" method="POST">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" placeholder="user@mail.com" required>
                </div>
                <div class="mb-2">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                </div>
                <div class="text-end mb-3">
                    <a href="/auth/forgot-password" class="forgot-link">
                        Forgot password?
                    </a>
                </div>
                <button type="submit" class="btn btn-login text-white w-100">
                    Login
                </button>
            </form>
            <p class="text-center mt-4 mb-0">
                Don’t have an account?
                <a href="/auth/signup">Signup</a>
            </p>
        </div>
    </div>
</body>

</html>