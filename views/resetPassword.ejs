<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Blogify • Reset Password</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #0d1026, #11142d);
        }

        .reset-card {
            background: rgba(255, 255, 255, 0.92);
            border-radius: 18px;
        }

        .logo-icon {
            width: 70px;
            height: 70px;
            background: #11142d;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
        }

        .logo-icon i {
            font-size: 2rem;
            color: white;
        }

        .brand {
            color: #11142d;
            font-weight: 600;
            letter-spacing: 1px;
            font-size: 1.8rem;
            margin-bottom: 0.3rem;
        }

        .subtitle {
            color: #6c757d;
            font-size: 0.95rem;
        }

        .form-label {
            font-weight: 500;
            color: #2c3e50;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .form-label i {
            font-size: 0.9rem;
        }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            font-size: 0.95rem;
        }

        .form-control {
            border-radius: 12px;
            padding: 11px 14px 11px 40px;
            border: 1px solid #dee2e6;
        }

        .form-control:focus {
            border-color: #11142d;
            box-shadow: 0 0 0 0.15rem rgba(17, 20, 45, 0.2);
        }

        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #6c757d;
            font-size: 0.95rem;
        }

        .password-toggle:hover {
            color: #11142d;
        }

        .info-box {
            background-color: #e3f2fd;
            border-left: 4px solid #3498db;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }

        .info-box p {
            margin: 0;
            color: #1976d2;
            font-size: 0.9rem;
        }

        .btn-reset {
            background-color: #11142d;
            border: none;
            border-radius: 12px;
            padding: 10px;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .btn-reset::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: left 0.5s ease;
        }

        .btn-reset:hover::before {
            left: 100%;
        }

        .btn-reset:hover {
            background-color: #1a1e4f;
            box-shadow: 0 8px 20px rgba(17, 20, 45, 0.4);
        }

        a {
            color: #11142d;
            font-weight: 500;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .back-link {
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            justify-content: center;
        }
    </style>
</head>

<body>
    <div class="container d-flex justify-content-center align-items-center min-vh-100">
        <div class="card shadow-lg p-4 reset-card" style="width: 100%; max-width: 420px;">
            <div class="text-center mb-4">
                <div class="logo-icon">
                    <i class="fas fa-lock"></i>
                </div>
                <h3 class="brand mb-2">Reset Password</h3>
                <p class="subtitle mb-0">Enter the OTP sent to your email</p>
            </div>

            <div class="info-box">
                <p><i class="fas fa-info-circle"></i> Check your email for the 6-digit OTP code. It's valid for 10 minutes.</p>
            </div>

            <form action="/auth/reset-password" method="POST">
                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-envelope"></i>
                        Email Address
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="email" class="form-control" placeholder="Enter your email" 
                               value="<%= typeof email !== 'undefined' ? email : '' %>" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-key"></i>
                        OTP Code
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-key input-icon"></i>
                        <input type="text" name="otp" class="form-control" placeholder="Enter 6-digit OTP" 
                               maxlength="6" pattern="[0-9]{6}" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        <i class="fas fa-lock"></i>
                        New Password
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="password" id="password" class="form-control" 
                               placeholder="Enter new password" required>
                        <i class="fas fa-eye-slash password-toggle" id="togglePassword"></i>
                    </div>
                </div>

                <button type="submit" class="btn btn-reset text-white w-100 mt-2">
                    <i class="fas fa-check-circle"></i> Reset Password
                </button>
            </form>

            <p class="text-center mt-4 mb-0">
                <a href="/auth/login" class="back-link">
                    <i class="fas fa-arrow-left"></i>
                    Back to Login
                </a>
            </p>
        </div>
    </div>

    <script>
        // Password toggle functionality
        const togglePassword = document.getElementById('togglePassword');
        const password = document.getElementById('password');

        togglePassword?.addEventListener('click', function() {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);
            this.classList.toggle('fa-eye');
            this.classList.toggle('fa-eye-slash');
        });
    </script>
</body>

</html>
