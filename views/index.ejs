<%- include('./partials/start.ejs') %>
  <div class="col-lg-10 p-4" id="content-area">
    <style>
      #content-area {
        background-color: #f8f9fa;
        min-height: calc(100vh - 56px);
      }

      .dashboard-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #11142d;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.8rem;
      }

      .dashboard-subtitle {
        color: #6c757d;
        font-size: 0.95rem;
        margin-top: 0.3rem;
      }

      .stats-container {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        margin-top: 2rem;
      }

      .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
        flex: 1;
        border-left: 4px solid #3498db;
      }

      .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #11142d;
      }

      .stat-label {
        color: #6c757d;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .modern-blog-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        border: 1px solid #e9ecef;
        height: 100%;
        display: flex;
        flex-direction: column;
      }

      .modern-blog-card:hover {
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
      }

      .modern-blog-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-bottom: 3px solid #3498db;
      }

      .modern-blog-body {
        padding: 1.3rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
      }

      .blog-tags-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 0.8rem;
      }

      .modern-tag {
        background-color: #e3f2fd;
        color: #1976d2;
        padding: 0.3rem 0.7rem;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
      }

      .author-badge {
        background-color: #f8f9fa;
        color: #495057;
        padding: 0.3rem 0.7rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }

      .modern-blog-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 0.7rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .modern-blog-desc {
        color: #6c757d;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 1rem;
        flex-grow: 1;
      }

      .blog-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 1rem;
        border-top: 1px solid #e9ecef;
        margin-top: auto;
      }

      .btn-read {
        background-color: #11142d;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s;
        border: none;
      }

      .btn-read:hover {
        background-color: #1c1f4a;
        color: white;
      }

      .action-buttons {
        display: flex;
        gap: 0.5rem;
      }

      .btn-edit {
        background-color: #10b981;
        color: white;
        padding: 0.5rem 0.9rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s;
        border: none;
      }

      .btn-edit:hover {
        background-color: #059669;
        color: white;
      }

      .btn-delete {
        background-color: #ef4444;
        color: white;
        padding: 0.5rem 0.9rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s;
        border: none;
      }

      .btn-delete:hover {
        background-color: #dc2626;
        color: white;
      }
    </style>

    <div>
      <h1 class="dashboard-title">
        📊 Dashboard
      </h1>
      <p class="dashboard-subtitle">Manage all your blog posts in one place</p>
    </div>
    <div class="stats-container">
      <div class="stat-card">
        <div class="stat-number">
          <%= blogs.length %>
        </div>
        <div class="stat-label">Total Blogs</div>
      </div>
      <div class="stat-card" style="border-left-color: #10b981;">
        <div class="stat-number">
          <%= blogs.filter(b=> b.author).length %>
        </div>
        <div class="stat-label">Published</div>
      </div>
      <div class="stat-card" style="border-left-color: #f59e0b;">
        <div class="stat-number">
          <%= new Set(blogs.map(b=> b.author?.name)).size %>
        </div>
        <div class="stat-label">Authors</div>
      </div>
    </div>
    <div class="row g-4">
      <% blogs.map((blog)=> { %>
        <div class="col-sm-12 col-md-6 col-lg-4">
          <div class="modern-blog-card">
            <img src="/<%= blog.file %>" class="modern-blog-img" alt="<%= blog.name %>">
            <div class="modern-blog-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="blog-tags-row">
                  <% blog.tags.split(',').forEach(tag=> { %>
                    <span class="modern-tag">
                      <%= tag.trim() %>
                    </span>
                    <% }) %>
                </div>
                <span class="author-badge">
                  ✍️ <%= blog.author ? blog.author.name : 'Unknown' %>
                </span>
              </div>

              <h5 class="modern-blog-title">
                <%= blog.name %>
              </h5>

              <p class="modern-blog-desc">
                <%= blog.desc.length> 120 ? blog.desc.slice(0, 120) + '...' : blog.desc %>
              </p>

              <div class="blog-actions">
                <a href="/blog/<%= blog._id %>" class="btn-read">
                  Read More →
                </a>
                <div class="action-buttons">
                  <a href="/blog/edit-blog/<%= blog._id %>" class="btn-edit">
                    <i class="fas fa-edit"></i>
                    Edit
                  </a>
                  <a href="/blog/delete-blog/<%= blog._id %>" class="btn-delete">
                    <i class="fas fa-trash-alt"></i>
                    Delete
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
    </div>
  </div>
  <%- include('./partials/end.ejs') %>
