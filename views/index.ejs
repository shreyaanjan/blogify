<%- include('./partials/start.ejs') %>
  <div class="col-lg-10 p-4" id="content-area">
    <div class="row g-4">
      <% blogs.map((blog)=> { %>
        <div class="col-sm-12 col-md-6 col-lg-4">
          <div class="card blog-card h-100 border-0 shadow-sm">
            <img src="/<%= blog.file %>" class="card-img-top blog-img" alt="<%= blog.name %>">
            <div class="card-body d-flex flex-column text-start">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                  <% blog.tags.split(',').forEach(tag=> { %>
                    <span class="badge me-1 custom-tag">
                      <%= tag.trim() %>
                    </span>
                    <% }) %>
                </div>
                <span class="text-muted small">
                  By <strong>
                    <%= blog.author ? blog.author.name : 'Unknown Author' %>
                  </strong>
                </span>
              </div>
              <div class="mb-2">
                <h5 class="card-title mb-0">
                  <%= blog.name %>
                </h5>
              </div>
              <p class="card-text text-muted">
                <%= blog.desc.length> 120
                  ? blog.desc.slice(0, 120) + '...'
                  : blog.desc %>
              </p>
              <div class="mt-auto d-flex justify-content-between align-items-center">
                <a href="/blog/<%= blog._id %>" class="btn btn-sm read-btn">
                  Read More
                </a>
                <div class="d-flex gap-2">
                  <a href="/blog/edit-blog/<%= blog._id %>" class="btn btn-sm btn-success">
                    Edit
                  </a>
                  <a href="/blog/delete-blog/<%= blog._id %>" class="btn btn-sm btn-danger">
                    Delete
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
    </div>
  </div>
  <%- include('./partials/end.ejs') %>